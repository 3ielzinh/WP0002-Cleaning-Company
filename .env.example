# Comma-separated ChatGPT account emails allowed to open /admin.
ADMIN_EMAILS=

# n8n lead delivery. The webhook receives signed JSON in x-sparclean-signature.
N8N_LEAD_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
AUTOMATION_SECRET=

# Twilio incoming Voice webhook validation and canonical public callback origin.
TWILIO_AUTH_TOKEN=
TWILIO_PUBLIC_BASE_URL=

# Cloudflare Turnstile widget keys. Configure both or neither.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional Google integrations.
GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
